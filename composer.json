{
    "name": "devouted/request-mapper",
    "description": "Symfony attributes for mapping HTTP request headers, path parameters and uploaded files to object constructor parameters",
    "type": "symfony-bundle",
    "license": "MIT",
    "require": {
        "php": ">=8.2",
        "symfony/http-foundation": "^6.4 || ^7.0",
        "symfony/serializer": "^6.4 || ^7.0"
    },
    "autoload": {
        "psr-4": {
            "RequestMapper\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "RequestMapper\\Tests\\": "tests/"
        }
    }
}
